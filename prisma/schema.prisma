generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── 인증 / 사용자 ──────────────────────────────────────────

enum UserRole {
  ITEM_WRITE      // 품번 생성/편집
  ITEM_DELETE     // 품번 삭제
  LAB_STOCK       // 연구소 재고 관리
  PROD_STOCK      // 생산구매팀 재고 관리
  MASTER_ADMIN    // 마스터 관리자
  ACCESS_BLOCKED  // 로그인 차단
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  emailVerified DateTime?
  name          String?
  image         String?
  roles         UserRole[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  accounts          Account[]
  sessions          Session[]
  stockTransactions StockTransaction[]
  purchaseRequests  PurchaseRequest[]
  itemRequests      ItemCreateRequest[]
  stockAudits       StockAudit[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── 품목 분류 ──────────────────────────────────────────────

enum ItemCategory {
  PRODUCT   // 제품
  ASSEMBLY  // 어셈블리
  COMPONENT // 컴포넌트
}

enum ItemStatus {
  ACTIVE       // 사용
  INACTIVE     // 미사용
  RESTRICTED   // 사용금지
  DISCONTINUED // 단종
}

// ── 재고 ──────────────────────────────────────────────────

enum Department {
  LAB        // 연구소
  PRODUCTION // 생산구매팀
}

enum StockTxType {
  IN       // 입고
  OUT      // 출고
  TRANSFER // 이관
  ADJUST   // 재고 조정
}

// ── 구매 요청 ──────────────────────────────────────────────

enum PurchaseStatus {
  PENDING  // 검토중
  APPROVED // 승인
  ORDERED  // 발주
  RECEIVED // 입고완료
  REJECTED // 반려
}

model Item {
  id   String @id @default(cuid())
  itemCode String @unique
  itemName String
  unit     String

  // 분류
  category       ItemCategory
  subCategory    String?      // 배터리팩(BP), BMS(B), PCM(PC) 등
  revisionNumber Int?         // 리비전 No. — 제품/BMS/PCM 코드의 버전
  status         ItemStatus   @default(ACTIVE)
  memo           String?

  // 물리적 속성 (어셈블리, 제품, 컴포넌트)
  length      Decimal? @db.Decimal(10, 2) // 가로/길이(mm)
  width       Decimal? @db.Decimal(10, 2) // 세로/폭(mm)
  height      Decimal? @db.Decimal(10, 2) // 높이(mm)
  diameter    Decimal? @db.Decimal(10, 2) // 직경(mm)
  weight      Decimal? @db.Decimal(10, 2) // 무게(g)
  innerLength Decimal? @db.Decimal(10, 2) // 내경 가로(mm)
  innerWidth  Decimal? @db.Decimal(10, 2) // 내경 세로(mm)
  innerHeight Decimal? @db.Decimal(10, 2) // 내경 높이(mm)
  thickness   Decimal? @db.Decimal(10, 2) // 두께(mm)
  material    String?  // 알루미늄, 플라스틱, 나무, 스틸, 고무, 실리콘
  packType    String?  // 소프트팩, 하드팩

  // 전기화학 (BMS, 셀, 제품)
  chemistryType String? // NMC, LFP, NCA, LTO, LMFP, LMO, LCO, LNMO, LCP, LI-PO
  seriesCount   Int?    // 직렬 정수(S)

  // 셀/제품 구성
  cellModel     String? // LGES H51, SDI 40T 등
  parallelCount Int?    // 병렬 정수(P)
  circuit       String? // BMS, PCM
  layerCount    Int?    // 단 수

  // 전기 사양 (셀, 제품)
  dischargeCutoffVoltage     Decimal? @db.Decimal(10, 2) // 방전종료전압(V)
  nominalVoltage             Decimal? @db.Decimal(10, 2) // 공칭전압(V)
  chargeCutoffVoltage        Decimal? @db.Decimal(10, 2) // 충전종료전압(V)
  nominalCapacity            Decimal? @db.Decimal(10, 3) // 공칭용량(Ah)
  energy                     Decimal? @db.Decimal(12, 2) // 에너지(Wh)
  maxChargeCurrent           Decimal? @db.Decimal(10, 2) // 피크충전전류(A)
  maxDischargeCurrent        Decimal? @db.Decimal(10, 2) // 피크방전전류(A)
  continuousChargeCurrent    Decimal? @db.Decimal(10, 2) // 연속충전전류(A) — BMS, 셀, 제품
  continuousDischargeCurrent Decimal? @db.Decimal(10, 2) // 연속방전전류(A) — BMS, 셀, 제품
  chargeCRate                Decimal? @db.Decimal(10, 2) // 충전 C-rate
  dischargeCRate             Decimal? @db.Decimal(10, 2) // 방전 C-rate

  // BMS 전용
  manufacturer   String?  // 제조사 (CTNS, 달리)
  ratedVoltage   Decimal? @db.Decimal(10, 2) // 정격전압(V)
  minSeriesCount Int?     // 최소 직렬 수
  maxSeriesCount Int?     // 최대 직렬 수
  maxVoltage     Decimal? @db.Decimal(10, 2) // 최대허용전압(V)

  // EL 컴포넌트 전용
  ratedCurrent   Decimal? @db.Decimal(10, 2) // 정격전류(A)

  // 모든 품목 공통 (다중 선택 → 배열)
  vendors        String[] // 거래처

  // 제품 전용 (다중 선택 → 배열)
  specialOptions String[] // 특수옵션
  certifications String[] // 인증

  // 파일 (URL 배열)
  drawings   String[] // 도면 (어셈블리, 제품)
  specSheets String[] // 스펙시트 (셀)
  images     String[] // 이미지

  // 컴포넌트 전용
  color String? // 색상

  // 셀 전용
  formFactor String? // 원통형, 각형, 파우치

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bomAsParent       BOM[]                @relation("ParentItem")
  bomAsChild        BOM[]                @relation("ChildItem")
  stocks            Stock[]
  stockTransactions StockTransaction[]
  costs             ItemCost[]
  stockCostLayers   StockCostLayer[]
  supplierItems     SupplierItem[]
  purchaseItems     PurchaseRequestItem[]
}

model ItemCost {
  id        String   @id @default(cuid())
  itemId    String
  currency  String   @default("KRW") // KRW, USD, EUR, CNY, JPY
  unitPrice Decimal  @db.Decimal(15, 4)
  supplier  String?
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)
}

model Stock {
  id         String     @id @default(cuid())
  itemId     String
  department Department
  quantity   Float      @default(0)
  memo       String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  item Item @relation(fields: [itemId], references: [id])

  @@unique([itemId, department])
}

model StockTransaction {
  id       String      @id @default(cuid())
  itemId   String
  type     StockTxType
  fromDept Department?
  toDept   Department?
  quantity Float
  memo     String?
  userId   String?
  unitCost  Decimal? @db.Decimal(15, 4)
  currency  String?
  createdAt DateTime   @default(now())

  item Item  @relation(fields: [itemId], references: [id])
  user User? @relation(fields: [userId], references: [id])
}

model PurchaseRequest {
  id           String         @id @default(cuid())
  documentNo    String?        @unique // 구매코드 (자동부여, 중복 불가)
  title         String
  requesterName String?        // 요청자 이름 (자유입력)
  department    String         @default("생산구매팀")
  requestDate  DateTime       @default(now())
  status       PurchaseStatus @default(PENDING)
  memo         String?
  requesterId  String?
  approvalLine String?        // JSON: [{order,role,name}]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  // ── 기타 구매 요청 전용 ──────────────────────────────────
  miscWorkCode    String?   // 프로젝트코드
  miscSupplier    String?   // 공급처
  miscUrl         String?   // URL
  miscTotalAmount Float?    // 총금액 (원)
  miscDocumentRef String?   // 품의서번호 (30만원 이상)
  miscDeliveryLoc  String?   // 배송지
  miscOrderMethod  String?   // 주문방식 (이메일/전화/온라인)
  cardUsed         String?   // 사용 카드 (구매처리)
  miscPaymentType  String?   // 구매처리 구분 (카드/연구비 계좌이체/자계좌 이체)
  miscExpenseRef   String?   // 비즈플레이 지출결의서 번호
  miscTaxInvoice   String?   // 세금계산서 발행 여부 (Y/N)
  miscActualAmount Float?    // 실결제액
  miscMemo         String?   // 비고 (구매처리)

  requester User?                  @relation(fields: [requesterId], references: [id])
  items     PurchaseRequestItem[]
  files     PurchaseFile[]
}

model PurchaseRequestItem {
  id                String  @id @default(cuid())
  purchaseRequestId String
  lineNo            Int

  // ── 요청자 작성 ──────────────────────────────────────────
  workCode              String?   // 프로젝트코드
  itemId                String?   // 품목 FK
  category              String?   // 대분류
  midCategory           String?   // 중분류
  subCategory           String?   // 소분류
  bomNo                 String?   // 품목코드
  spec                  String?   // 품목명
  quantity              Float
  unit                  String    @default("EA")
  currency              String?   @default("KRW") // 통화 (KRW/USD/CNY)
  supplyAmount          Float?    // 공급금액
  taxAmount             Float?    // 세액
  purchaseReason        String?   // 구매사유
  requestedDeliveryDate DateTime? // 입고희망일
  supplier              String?   // 공급자
  deliveryLocation      String?   // 입고장소 (창원/부산)

  // ── 구매자 작성 ──────────────────────────────────────────
  domestic              String?   // 국내/해외
  orderMethod           String?   // 주문방식 (이메일/전화/온라인/방문)
  orderNo               String?   // 주문번호
  plannedShipDate       DateTime? // 출고예정일
  actualShipDate        DateTime? // 출고일
  shippingMethod        String?   // 운송방법 (해운/항공/업체 직배송)
  trackingNo            String?   // 송장번호
  boxCount              Int?      // 박스수량
  remittanceDate        DateTime? // 송금일
  paymentDate           DateTime? // 결제일
  buyerCurrency         String?   // 통화 (구매자)
  buyerSupplyAmount     Float?    // 공급금액 (구매자)
  buyerTaxAmount        Float?    // 세액 (구매자)
  additionalCost        Float?    // 부대비용
  portArrivalDate       DateTime? // 항구도착일
  loadingDate           DateTime? // 선적일
  estimatedArrivalDate  DateTime? // 도착예정일
  actualReceiptDate     DateTime? // 입고일
  blNo                  String?   // BL No.
  buyerMemo             String?   // 비고
  exchangeRate          Float?    // 환율 (결제 시점 기준)
  krwAmount             Float?    // 원화 환산 금액
  unitPrice             Float?    // 단가 (구매금액 ÷ 수량)
  boxUnitQty            Float?    // 박스별 수량
  paymentMethod         String?   // 정산구분 (계좌이체/카드/현금/어음)
  payBankName           String?   // 정산 - 은행
  payAccountNumber      String?   // 정산 - 계좌번호
  payAccountHolder      String?   // 정산 - 예금주

  purchaseRequest PurchaseRequest @relation(fields: [purchaseRequestId], references: [id], onDelete: Cascade)
  item            Item?           @relation(fields: [itemId], references: [id])
}

model PurchaseFile {
  id                String          @id @default(cuid())
  purchaseRequestId String
  fileName          String
  fileUrl           String
  fileType          String?         // 견적서, 발주서, 기타
  fileSize          Int?
  uploadedAt        DateTime        @default(now())

  purchaseRequest PurchaseRequest @relation(fields: [purchaseRequestId], references: [id], onDelete: Cascade)
}

model BOM {
  id       String  @id @default(cuid())
  parentId String
  childId  String
  quantity Float
  unit     String
  memo     String?

  parent Item @relation("ParentItem", fields: [parentId], references: [id])
  child  Item @relation("ChildItem", fields: [childId], references: [id])

  @@unique([parentId, childId])
}

model ItemCodeHistory {
  itemCode  String   @id
  createdAt DateTime @default(now())
}

// ── 공유 옵션 저장소 ────────────────────────────────────────
// key: '__store__' (일반 옵션), '__groups__' (셀모델 그룹)
model AppOption {
  key       String   @id
  data      Json
  updatedAt DateTime @updatedAt
}

// ── 재고 원가 레이어 (FIFO) ─────────────────────────────────

model StockCostLayer {
  id         String     @id @default(cuid())
  itemId     String
  department Department
  unitCost   Decimal    @db.Decimal(15, 4)
  currency   String     @default("KRW")
  origQty    Float
  remainQty  Float
  createdAt  DateTime   @default(now())

  item Item @relation(fields: [itemId], references: [id])
}

// ── 재고 실사 ──────────────────────────────────────────────

model StockAudit {
  id         String           @id @default(cuid())
  department Department
  note       String?
  auditedBy  String?
  auditedAt  DateTime         @default(now())

  items StockAuditItem[]
  user  User?            @relation(fields: [auditedBy], references: [id])
}

model StockAuditItem {
  id          String  @id @default(cuid())
  auditId     String
  itemId      String?
  itemCode    String
  itemName    String
  unit        String
  category    String?
  subCategory String?
  systemQty   Float
  actualQty   Float?

  audit StockAudit @relation(fields: [auditId], references: [id], onDelete: Cascade)
}

// ── 구매 카드 ──────────────────────────────────────────────

model PurchaseCard {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
}

// ── 품목 생성 요청 ──────────────────────────────────────────

enum ItemRequestStatus {
  PENDING  // 검토중
  APPROVED // 승인
  REJECTED // 반려
}

model ItemCreateRequest {
  id            String            @id @default(cuid())
  status        ItemRequestStatus @default(PENDING)
  requesterId   String?
  requesterName String?
  category      String
  subCategory   String?
  itemName      String
  spec          String?
  quantity      Float?
  unit          String?
  workCode      String?
  memo          String?
  reviewMemo    String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  requester User? @relation(fields: [requesterId], references: [id])
}

// ── 공급처 관리 ────────────────────────────────────────────

enum SupplierStatus {
  ACTIVE   // 사용
  INACTIVE // 미사용
}

enum SupplierRegion {
  DOMESTIC // 국내
  OVERSEAS // 해외
}

model Supplier {
  id              String         @id @default(cuid())
  supplierCode    String         @unique
  companyName     String
  status          SupplierStatus @default(ACTIVE)
  region          SupplierRegion @default(DOMESTIC)
  businessRegNo   String?
  url             String?
  bankName        String?
  accountNumber   String?
  accountHolder   String?
  subCategory     String?
  note            String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  contacts SupplierContact[]
  items    SupplierItem[]
  files    SupplierFile[]
}

model SupplierContact {
  id         String   @id @default(cuid())
  supplierId String
  name       String
  title      String?
  phone      String?
  email      String?
  createdAt  DateTime @default(now())

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
}

model SupplierItem {
  supplierId String
  itemId     String

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  item     Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@id([supplierId, itemId])
}

model SupplierFile {
  id         String   @id @default(cuid())
  supplierId String
  fileName   String
  fileUrl    String
  fileSize   Int?
  mimeType   String?
  createdAt  DateTime @default(now())

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
}
